<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ARYAN KATAKDHOND | Portfolio</title>
  <style>
    * {
      box-sizing: border-box;
    }
    body {
      margin: 0;
      font: 16px/1.6 Arial, sans-serif;
      color: #1f1a17;
      background: linear-gradient(180deg, #f6efe6, #f4e7da);
    }
    main {
      max-width: 1000px;
      margin: auto;
      padding: 20px;
    }
    header,
    section {
      margin: 16px 0;
      padding: 20px;
      background: rgba(255, 250, 244, 0.92);
      border: 1px solid rgba(95, 64, 45, 0.14);
      border-radius: 22px;
      box-shadow: 0 16px 40px rgba(76, 44, 27, 0.1);
    }
    .hero {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 16px;
      align-items: center;
    }
    .tag {
      display: inline-block;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(200, 91, 47, 0.1);
      color: #9b4322;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    h1,
    h2,
    h3 {
      margin: 0 0 10px;
      font-family: Georgia, serif;
      line-height: 1.1;
    }
    h1 {
      font-size: clamp(2.6rem, 6vw, 4.6rem);
    }
    .sub {
      margin: 0;
      color: #9b4322;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .muted {
      color: #6b5d53;
    }
    .btns {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 18px;
    }
    a.btn {
      text-decoration: none;
      padding: 12px 16px;
      border-radius: 999px;
      font-weight: 700;
    }
    .dark {
      background: #1f1a17;
      color: #fff;
     
    }
    .light {
      border: 1px solid rgba(31, 26, 23, 0.14);
      color: #1f1a17;
    }
    .profile {
      display: grid;
      place-items: center;
      min-height: 190px;
      color: #fff;
      background: linear-gradient(135deg, #8e4d31, #c87a50 55%, #ead0b5);
    }
    .profile img {
      width: min(100%, 340px);
      aspect-ratio: 1 / 1.05;
      object-fit: box-cover;
      border-radius: 2px;
      box-shadow: 0 18px 40px rgba(45, 24, 15, 0.22);
    }
    .grid,
    .skills,
    .contact {
      display: grid;
      gap: 12px;
    }
    .grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .skills {
      grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    }
    .pill,
    .card,
    .contact div {
      background: #fff;
      border: 1px solid rgba(95, 64, 45, 0.1);
      border-radius: 16px;
      padding: 14px;
    }
    .contact {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    @media (max-width: 800px) {
      .hero,
      .grid,
      .contact {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 520px) {
      main {
        padding: 12px;
      }
      header,
      section {
        padding: 16px;
        border-radius: 18px;
      }
    }
  </style>
</head>
<body>
<main>
  <header class="hero">
    <div>
      <span class="tag">Portfolio</span>
      <h1>ARYAN KATAKDHOND</h1>
      <p class="sub">Computer Engineer</p>
      <p class="muted">Learner and tech enthusiast focused on practical web projects and steady improvement.</p>
      <div class="btns"><a class="btn light" href="#projects">View Projects</a><a class="btn light" href="#contact">Contact Me</a></div>
    </div>
    <div class="profile" aria-label="Profile photo">
      <img src="IMG_20260702_163012.jpg" alt="ARYAN KATAKDHOND standing outdoors in a black suit">
    </div>
  </header>
  <section>
    <h2>About Me</h2>
    <p class="muted">Learner and tech enthusiast.</p>
  </section>
  <section>
    <h2>Skills</h2>
    <div class="skills"><span class="pill">JavaScript</span><span class="pill">HTML</span><span class="pill">CSS</span><span class="pill">Python</span><span class="pill">SQL</span></div>
  </section>
  <section id="projects">
    <h2>Projects</h2>
    <div class="grid">
      <div class="card"><h3>Calculator</h3><p class="muted">Simple calculator built with HTML, CSS, and JavaScript.</p></div>
      <div class="card"><h3>Temperature Converter</h3><p class="muted">Small unit conversion tool with a clean interface.</p></div>
      <div class="card"><h3>Landing Page</h3><p class="muted">Responsive landing page focused on layout and design.</p></div>
    </div>
  </section>
  <section id="contact">
    <h2>Contact</h2>
    <div class="contact">
      <div><strong>Phone</strong><br><a>9876543210</a></div>
      <div><strong>Email</strong><br><span class="muted">aryankatakhond@gmail.com</span></div>
    </div>
  </section>
</main>
</body>
</html>
